<div class="container">

  <div class="row">
    <div class="col-lg-12">
      <h1>Companies</h1>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-12">

    <input type="text" id="filterInput" onkeyup="filtertable()" placeholder="Search">

    <div class="table-container">
      <table class="data-table" id="filtertable">
        <thead>
        <tr>
          <th>Name</th>
          <th></th>
          <th></th>
          <th></th>
          <th></th>
        </tr>
        </thead>

        <tbody>
        <% @companies.each do |company| %>
          <tr>
            <td><%= company.name %></td>
            <td><%= link_to 'Bulk License Update', bulk_edit_company_licenses_path(company) %></td>
            <td><%= link_to 'Show', company %></td>
            <td><%= link_to 'Edit', edit_company_path(company) %></td>
            <td><%= link_to 'Destroy', company, method: :delete, data: { confirm: 'Are you sure?' } %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

      <br>

      <%= link_to 'New Company', new_company_path %>

    </div>
  </div>


</div>

