<div class="container">
  <div class="row">
    <div class="col-lg-12">
      <h2>
        <%= @company.name %>
      </h2>
    </div>
  </div>

  <div class="row mt-4 pt-2 border border-info rounded">
    <div class="col-lg-12">
      <h4>Licenses:</h4>
      <table class="table">
        <thead>
        <tr>
          <th>Name</th>
          <th>Status</th>
          <th>Type</th>
          <th colspan="3"></th>
        </tr>
        </thead>

        <tbody>
        <% @company.licenses.each do |license| %>
          <tr>
            <td><%= license.name %></td>
            <% if license.user.nil? %>
              <td>Not checked out</td>
            <% else %>
              <td><%= license.user.email %></td>
            <% end %>
            <td><%= license.license_type %></td>
            <td><%= link_to 'Show', license %></td>
            <td><%= link_to 'Edit', edit_license_path(license) %></td>
            <td><%= link_to 'Destroy', license, method: :delete, data: { confirm: 'Are you sure?' } %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="row mt-4 pt-2 border border-info rounded">
    <div class="col-lg-12">
      <h4>Users:</h4>
      <table class="table">
        <thead>
        <tr>
          <th>Email</th>
          <th>Minutes (7-day)</th>
          <th>Clicks (7-day)</th>
          <th>Minutes (24-hour)</th>
          <th>Clicks (24-hour)</th>
          <th>Version</th>
          <th colspan="1"></th>
        </tr>
        </thead>

        <tbody>
        <% @company.users.each do |user| %>
          <tr>
            <td><%= user.email %></td>
            <td><%= user.minutes_active_this_week %></td>
            <td><%= user.minutes_active_24h %></td>
            <td><%= user.clicks_this_week %></td>
            <td><%= user.clicks_24h %></td>
            <td><%= user.current_application_version %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-lg-12">
      <%= link_to 'Edit', edit_company_path(@company) %> |
      <%= link_to 'Back', companies_path %>
    </div>
  </div>

</div>


