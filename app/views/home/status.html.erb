<div class="container">
  <div class="row">
    <div class="col-lg-12">
      <h2>
        <%= @company.name %>
      </h2>
      <h5>License expiry: <%= @company.license_expiration %></h5>
    </div>
  </div>

  <div class="row mt-4 pt-2 border border-info rounded">
    <div class="col-lg-12">
      <h4>Licenses:</h4>
      <table class="table">
        <thead>
        <tr>
          <th>Name</th>
          <th>Status</th>
          <th>Expiry Date</th>
          <th>Type</th>
          <th colspan="3"></th>
        </tr>
        </thead>

        <tbody>
        <% @company.licenses.each do |license| %>
          <tr>
            <td><%= license.name %></td>
            <% if license.user.nil? %>
              <td>Not checked out</td>
            <% else %>
              <td><%= license.user.email %></td>
            <% end %>
            <td><%= license.expiry_date %></td>
            <td><%= license.license_type %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="row mt-4 pt-2 border border-info rounded">
    <div class="col-lg-12">
      <h4>Users:</h4>
      <table class="table">
        <thead>
        <tr>
          <th>Email</th>
          <th colspan="1"></th>
        </tr>
        </thead>

        <tbody>
        <% @company.users.each do |user| %>
          <tr>
            <td><%= user.email %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>


