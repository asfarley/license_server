<div class="container">
  <div class="row">
    <div class="col-lg-12">
      <h2>Create User</h2>

      <%= form_with(model: @newuser) do |f| %>

        <div class="field">
          <%= f.label :email %><br />
          <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
        </div>

        <div class="field">
          <%= f.label :company_id %>
          <%= f.select :company_id, options_for_select(Company.all.map{ |c| [c.name, c.id]}), :include_blank => true %>
        </div>

        <div class="field">
          <%= f.label :password %>
          <% if @minimum_password_length %>
            <em>(<%= @minimum_password_length %> characters minimum)</em>
          <% end %><br />
          <%= f.password_field :password, autocomplete: "new-password" %>
        </div>

        <div class="field">
          <%= f.label :password_confirmation %><br />
          <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
        </div>

        <div class="actions">
          <%= f.submit "Create" %>
        </div>
      <% end %>

      
    </div>
  </div>
</div>


