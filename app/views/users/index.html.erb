<div class="container">

  <div class="row">
    <div class="col-lg-12">
      <h1>User Management</h1>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-12">
      <%= link_to 'Add User', new_user_path %>
    </div>
  </div>


  <div class="row">
    <div class="col-lg-12">
      <input type="text" id="filterInput" onkeyup="filtertable()" placeholder="Search">

    <div class="table-container">
      <table class="data-table" id="filtertable">
        <thead>
        <tr>
          <th>email</th>
          <th>Company</th>
          <th colspan="3"></th>
        </tr>
        </thead>

        <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.email %></td>
            <td>
              <%= user.company_name %>
            </td>
            <td><%= link_to 'Edit', edit_user_path(user) %></td>
            <% if user.has_role?(:admin) %>
              <td><%= link_to 'Remove Admin', {:controller => :users, :action => :unset_admin, id: user.id}, method: 'patch' %></td>
              <% else %>
              <td><%= link_to 'Make Admin', {:controller => :users, :action => :set_admin, id: user.id}, method: 'patch' %></td>
            <% end %>
            <td><%= link_to 'Destroy', user, method: :delete, data: { confirm: 'Are you sure?' } %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
      </div>
      <br>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-12">
      <%= link_to 'Email list', 'users/emails' %>
    </div>
  </div>

</div>

