<div class="container">
  <div class="row">
    <div class="col-lg-12">
      <p>
        <strong>Name:</strong>
        <%= @license.name %>
      </p>

      <p>
        <strong>Company:</strong>
        <%= @license.company.name %>
      </p>

      <p>
        <strong>Type:</strong>
        <%= @license.license_type %>
      </p>

      <p>
        <strong>Expiry Date:</strong>
        <%= @license.expiry_date %>
      </p>

      <p>
        <strong>Status:</strong>
        <% if @license.checkedout == false %>
        <td>Not checked out</td>
        <% elsif @license.checkedout == true && @license.user.nil? == false %>
        <td>Checked out by <span class="text-info"><%= @license.user.email %></span></td>
        <% elsif @license.checkedout == true && @license.user.nil? == true %>
            <td>License is in error state: checked out, but user is nil.</td>
        <% end %>
      </p>

      <%= link_to 'Edit', edit_license_path(@license) %> |
      <%= link_to 'Back', licenses_path %>
    </div>
  </div>
</div>


