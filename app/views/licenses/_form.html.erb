<%= form_with(model: license, local: true) do |form| %>
  <% if license.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(license.errors.count, "error") %> prohibited this license from being saved:</h2>

      <ul>
        <% license.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div class="field">
    <%= form.label :company_id %>
    <%= form.select :company_id, options_for_select(Company.all.map{ |c| [c.name, c.id]}, @license.company_id )%>
  </div>

  <div class="field">
    <%= form.label :license_type %>
    <%= form.select :license_type, options_for_select(License.license_types.map { |key, value| [key.humanize, key] }, @license.license_type) %>
  </div>

  <div class="field">
    <%= form.label :expiry_date %>
    <%= form.date_select :expiry_date, {:order => [:month, :day, :year],:prompt => true, :start_year => 2015, :end_year => 2040} %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
