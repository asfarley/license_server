<div class="container">

  <div class="row">
    <div class="col-lg-12">
      <h1>Licenses</h1>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-12">

    <input type="text" id="filterInput" onkeyup="filtertable()" placeholder="Search">

    <div class="table-container">
      <table class="data-table" id="filtertable">
        <thead>
        <tr>
          <th>Name</th>
          <th>Company</th>
          <th>Status</th>
          <th>Expiry Date</th>
          <th>Type</th>
          <th colspan="8"></th>
        </tr>
        </thead>

        <tbody>
        <% @licenses.each do |license| %>
          <tr>
            <td><%= license.name %></td>
            <td><%= license.company.name %></td>
            <% if license.user.nil? %>
              <td>Not checked out</td>
            <% else %>
              <td><%= license.user.email %></td>
            <% end %>
            <td><%= license.expiry_date %></td>
            <td><%= license.license_type %></td>
            <% if license.checkedout == false %>
              <td><%= link_to 'Check out', checkout_license_path(license), method: :post %></td>
            <% else %>
              <td><%= link_to 'Check in', checkin_license_path(license), method: :post %></td>
            <% end %>
            <td><%= link_to 'Show', license %></td>
            <td><%= link_to 'Edit', edit_license_path(license) %></td>
            <td><%= link_to 'Destroy', license, method: :delete, data: { confirm: 'Are you sure?' } %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

      <br>

      <%= link_to 'New License', new_license_path %>
    </div>
  </div>

</div>
